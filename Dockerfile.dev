# ─── 安全开发沙箱 ─────────────────────────────────
# 用途：AI 代理（Reasonix Code / Claude Code）和 Vite 都跑在容器内
#       即使 --yolo 模式失控，也碰不到宿主机文件系统
FROM node:20-alpine

# 工具：bash（Reasonix 需要）+ git（版本控制）
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.tuna.tsinghua.edu.cn/g' /etc/apk/repositories && \
    apk add --no-cache bash git

WORKDIR /workspace

# 预装项目依赖
COPY package.json package-lock.json ./
RUN npm ci

# 全局安装 Reasonix，避免每次 npx 重下
RUN npm install -g reasonix

# 默认启动 Vite 开发服务器
CMD ["npm", "run", "dev"]
