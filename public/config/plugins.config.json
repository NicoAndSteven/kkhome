    {
      "id": "universal-inbox",
      "enabled": true,
      "order": 3,
      "config": {
        "capsules": [
          {
            "id": "capsule-json",
            "title": "发送到 JSON 工具",
            "triggers": ["json"],
            "description": "识别 JSON 内容并激活 Workbench 的格式化工具",
            "icon": "data_object",
            "action": {
              "type": "select-tool",
              "label": "已激活 JSON 工具",
              "tool": "json-format",
              "target": "#workbench"
            }
          },
          {
            "id": "capsule-url",
            "title": "收纳链接",
            "triggers": ["url"],
            "description": "把 URL 作为临时链接写入 Scratchpad",
            "icon": "bookmark_add",
            "action": {
              "type": "add-scratchpad",
              "label": "已收纳链接",
              "target": "#scratchpad"
            }
          },
          {
            "id": "capsule-command",
            "title": "保存命令片段",
            "triggers": ["command"],
            "description": "把终端命令暂存，稍后可归档为 snippet",
            "icon": "terminal",
            "action": {
              "type": "add-scratchpad",
              "label": "已保存命令",
              "target": "#scratchpad"
            }
          },
          {
            "id": "capsule-timestamp",
            "title": "转换时间戳",
            "triggers": ["timestamp"],
            "description": "识别秒或毫秒时间戳并激活时间工具",
            "icon": "schedule",
            "action": {
              "type": "select-tool",
              "label": "已激活时间戳工具",
              "tool": "timestamp",
              "target": "#workbench"
            }
          },
          {
            "id": "capsule-base64",
            "title": "尝试 Base64 解码",
            "triggers": ["base64"],
            "description": "把疑似 Base64 的文本交给编码转换工具",
            "icon": "swap_horiz",
            "action": {
              "type": "select-tool",
              "label": "已激活 Base64 工具",
              "tool": "base64",
              "target": "#workbench"
            }
          },
          {
            "id": "capsule-prompt",
            "title": "收纳 Prompt",
            "triggers": ["prompt", "text"],
            "description": "把长文本或 Prompt 放入临时收纳区",
            "icon": "rate_review",
            "action": {
              "type": "add-scratchpad",
              "label": "已收纳文本",
              "target": "#scratchpad"
            }
          }
        ]
      }
