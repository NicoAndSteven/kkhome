            "category": "时间",
            "description": "把秒或毫秒时间戳转成 ISO 时间",
            "aliases": ["time", "timestamp"],
            "icon": "schedule"
          },
          {
            "id": "utility-uuid",
            "title": "UUID 生成",
            "type": "tool",
            "mode": "inline",
            "utilityType": "uuid",
            "category": "生成器",
            "description": "快速生成随机 UUID",
            "aliases": ["id"],
            "icon": "fingerprint"
          }
        ],
        "snippets": [
          {
            "id": "snippet-check",
            "title": "项目检查命令",
            "type": "snippet",
            "category": "命令",
            "description": "运行当前项目完整质量门禁",
            "content": "npm run check",
            "tags": ["npm", "check"],
            "aliases": ["verify", "ci"],
            "icon": "task_alt",
            "favorite": true
          },
          {
            "id": "prompt-review",
            "title": "审查 Prompt",
            "type": "prompt",
            "category": "Prompt",
            "description": "让审查者优先检查漏洞、方向偏差和缺失测试",
            "content": "请以代码审查视角检查这次改动，优先指出 bug、方向偏差、可维护性风险和缺失测试。",
            "tags": ["review", "prompt"],
            "aliases": ["review"],
            "icon": "rate_review"
          }
        ]
      }
