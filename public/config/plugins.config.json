          {
            "id": "utility-json",
            "title": "JSON 格式化",
            "type": "tool",
            "mode": "inline",
            "utilityType": "json-format",
            "category": "文本处理",
            "description": "格式化和校验 JSON 片段",
            "aliases": ["json"],
            "icon": "data_object",
            "favorite": true
          },
          {
            "id": "utility-base64",
            "title": "Base64 编解码",
            "type": "tool",
            "mode": "inline",
            "utilityType": "base64",
            "category": "编码转换",
            "description": "在普通文本和 Base64 之间转换",
            "aliases": ["b64"],
            "icon": "swap_horiz"
          },
          {
            "id": "utility-url",
            "title": "URL 编解码",
            "type": "tool",
            "mode": "inline",
            "utilityType": "url-codec",
            "category": "编码转换",
            "description": "处理 URL encode 和 decode",
            "aliases": ["url"],
            "icon": "link"
          },
          {
            "id": "utility-time",
            "title": "时间戳转换",
            "type": "tool",
            "mode": "inline",
