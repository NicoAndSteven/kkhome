      "config": {
        "items": [
          {
            "id": "project-homepage",
            "name": "个人主页",
            "description": "基于 React、TypeScript 和 Tailwind CSS 构建的配置驱动个人主页。",
            "techStack": ["React", "TypeScript", "Tailwind CSS", "Vite"]
          }
        ]
      }
    },
    {
      "id": "quick-launch",
      "enabled": true,
      "order": 4,
      "config": {
        "searchTargets": [
          {
            "id": "search-github",
            "title": "GitHub",
            "urlTemplate": "https://github.com/search?q={query}",
            "icon": "code"
          },
          {
            "id": "search-npm",
            "title": "npm",
            "urlTemplate": "https://www.npmjs.com/search?q={query}",
            "icon": "package_2"
          },
          {
            "id": "search-mdn",
            "title": "MDN",
            "urlTemplate": "https://developer.mozilla.org/search?q={query}",
            "icon": "article"
          },
          {
            "id": "search-bilibili",
